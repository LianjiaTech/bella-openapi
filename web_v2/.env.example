# 开发时直接启动推荐先开 Mock
NEXT_PUBLIC_USE_MOCK=true

# 真实后端地址
# 当 NEXT_PUBLIC_USE_MOCK=false 时，开发代理和服务端转发会使用这个地址
BACKEND_API_URL=http://localhost:8080

# 可选：暴露给浏览器的后端地址
# 用于客户端直连、调试日志和页面示例展示；不填时默认走相对路径
# NEXT_PUBLIC_API_ORIGIN=http://localhost:8080

# 可选：页面代码示例里的 OpenAI base_url
# NEXT_PUBLIC_DEFAULT_API_ENDPOINT=http://localhost:8080/v1

# 可选：文档按钮地址
# NEXT_PUBLIC_DOCS_URL=https://your-docs.example.com

# 兼容旧配置，已有部署可继续使用
# NEXT_PUBLIC_API_HOST=localhost:8080
